# Existing service paths and identity
PUID=1001
PGID=100
TZ=America/New_York
DOWNLOAD_DIR=/downloads
CONFIG_DIR=/config
SOUNDCLOUD_AUTH_TOKEN=

# Set true only after the 5-10 track smoke test. This runs one persistent
# per-track likes worker; the web UI remains available for one-off downloads.
SCDL_RELIABLE_SYNC_ENABLED=false
SCDL_MAX_CONCURRENT_DOWNLOADS=1
SCDL_BATCH_SIZE=500
SCDL_SMOKE_TEST_BATCH_SIZE=10
SCDL_MIN_TRACK_DELAY_SECONDS=150
SCDL_MAX_TRACK_DELAY_SECONDS=240
SCDL_HARD_MIN_DELAY_SECONDS=120
SCDL_TARGET_BATCH_MIN_HOURS=24
SCDL_TARGET_BATCH_MAX_HOURS=36
SCDL_METADATA_TIMEOUT_SECONDS=60
SCDL_MEDIA_RESOLVE_TIMEOUT_SECONDS=90
SCDL_CONNECT_TIMEOUT_SECONDS=30
SCDL_READ_TIMEOUT_SECONDS=300
SCDL_FFMPEG_TIMEOUT_SECONDS=1800
SCDL_COLLECTION_PAGE_TIMEOUT_SECONDS=90
# Zero disables a whole-scdl-process timer; active transfers are instead bounded
# by the read-inactivity timeout above.
SCDL_SUBPROCESS_TIMEOUT_SECONDS=0
SCDL_SUBPROCESS_TERMINATION_GRACE_SECONDS=15
SCDL_STALL_CONFIRMATION_SECONDS=30
SCDL_LIKES_CHECK_INTERVAL_MINUTES=30
SCDL_MIN_FREE_SPACE_GB=20
SCDL_DIAGNOSTIC_MODE=true
SCDL_DIAGNOSTIC_LOG_MAX_MB=100
SCDL_DIAGNOSTIC_LOG_BACKUP_COUNT=10
